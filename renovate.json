{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "labels": ["renovate", "dependencies"],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 15,
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Renovate Dependency Dashboard",
  "kubernetes": {
    "fileMatch": [
      "^apps/.+\\.ya?ml$",
      "^infrastructure/(metallb|kite|reloader)/manifests/.+\\.ya?ml$"
    ]
  },
  "helmv3": {
    "fileMatch": [
      "^infrastructure/(cert-manager|ingress-nginx|monitoring)/Chart\\.ya?ml$"
    ]
  },
  "packageRules": [
    {
      "matchFileNames": ["apps/bitwarden/**"],
      "groupName": "bitwarden",
      "groupSlug": "bitwarden"
    },
    {
      "matchFileNames": ["apps/ddclient/**"],
      "groupName": "ddclient",
      "groupSlug": "ddclient"
    },
    {
      "matchFileNames": ["apps/filebrowser/**"],
      "groupName": "filebrowser",
      "groupSlug": "filebrowser"
    },
    {
      "matchFileNames": ["apps/headscale/**"],
      "groupName": "headscale",
      "groupSlug": "headscale"
    },
    {
      "matchFileNames": ["apps/heimdall/**"],
      "groupName": "heimdall",
      "groupSlug": "heimdall"
    },
    {
      "matchFileNames": ["apps/homeassistant/**"],
      "groupName": "home-assistant",
      "groupSlug": "home-assistant"
    },
    {
      "matchFileNames": ["apps/immich/**"],
      "groupName": "immich",
      "groupSlug": "immich"
    },
    {
      "matchFileNames": ["apps/n8n/**"],
      "groupName": "n8n",
      "groupSlug": "n8n"
    },
    {
      "matchFileNames": ["apps/paperless/**"],
      "groupName": "paperless-ngx",
      "groupSlug": "paperless-ngx"
    },
    {
      "matchFileNames": ["apps/pihole/**"],
      "groupName": "pihole",
      "groupSlug": "pihole"
    },
    {
      "matchFileNames": ["apps/samba-share/**"],
      "groupName": "samba",
      "groupSlug": "samba"
    },
    {
      "matchFileNames": ["apps/speedtest/**"],
      "groupName": "speedtest-tracker",
      "groupSlug": "speedtest-tracker"
    },
    {
      "matchFileNames": ["apps/uptime-kuma/**"],
      "groupName": "uptime-kuma",
      "groupSlug": "uptime-kuma"
    },
    {
      "matchFileNames": ["apps/wireguard/**"],
      "groupName": "wireguard",
      "groupSlug": "wireguard"
    },
    {
      "matchFileNames": ["infrastructure/cert-manager/**"],
      "groupName": "infra: cert-manager",
      "groupSlug": "infra-cert-manager"
    },
    {
      "matchFileNames": ["infrastructure/ingress-nginx/**"],
      "groupName": "infra: ingress-nginx",
      "groupSlug": "infra-ingress-nginx"
    },
    {
      "matchFileNames": ["infrastructure/metallb/**"],
      "groupName": "infra: metallb",
      "groupSlug": "infra-metallb"
    },
    {
      "matchFileNames": ["infrastructure/kite/**"],
      "groupName": "infra: kite",
      "groupSlug": "infra-kite"
    },
    {
      "matchFileNames": ["infrastructure/reloader/**"],
      "groupName": "infra: reloader",
      "groupSlug": "infra-reloader"
    },
    {
      "matchFileNames": ["infrastructure/monitoring/**"],
      "groupName": "infra: monitoring",
      "groupSlug": "infra-monitoring"
    }
  ]
}
